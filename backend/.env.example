# Configuration de l'application
NODE_ENV=development
PORT=5000

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/muamokel-services

# JWT Configuration
JWT_SECRET=votre_cle_secrete_très_longue_et_complexe_ici_au_moins_32_caractères
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (pour récupération de mot de passe)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_app
EMAIL_FROM=noreply@muamokel-services.com

# Limites de sécurité
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=2h

# Autres configurations
BCRYPT_ROUNDS=12
